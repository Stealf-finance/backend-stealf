PORT=3000
NODE_ENV=production

# CORS — origines autorisées séparées par virgule
# Note: les builds natifs React Native n'envoient pas d'en-tête Origin → toujours autorisés
# Laisser vide pour bloquer toutes les requêtes web avec Origin en production
ALLOWED_ORIGINS=https://app.stealf.fi,https://staging.stealf.fi

MONGODB_URI=

REDIS_URL=

HELIUS_API_KEY=
# ⚠️ PRODUCTION: must be stable HTTPS URL (Railway/Render/VPS) — NOT an ngrok URL (expires)
# Example: https://api.stealf.app/api/helius/webhook
WEBHOOK_URL=
HELIUS_WEBHOOK_SECRET=

RESEND_API_KEY=
BACKEND_URL=
FRONTEND_URL=

SOLANA_RPC_URL=

# Auth
